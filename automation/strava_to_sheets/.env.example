# ----- Strava -----
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
# Long-lived refresh token from your Strava OAuth consent flow
STRAVA_REFRESH_TOKEN=your_refresh_token
# Random shared secret used by Strava webhook verification
STRAVA_VERIFY_TOKEN=choose_a_random_secret

# ----- Google Sheets -----
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_WORKSHEET_NAME=Activities

# ----- Local app -----
SQLITE_DB_PATH=state.db
LOG_LEVEL=INFO
